# ============================================================
# .env.example — Template for environment variables
# ============================================================
# PURPOSE: Shows other developers what env vars are needed.
# HOW TO USE: Copy this file to .env and fill in your values.
#   Command: cp .env.example .env  (then edit .env)
# WHY .env.example EXISTS: .env is gitignored (has secrets),
#   but developers need to know which vars to set.
# ============================================================

# Google Gemini API Key
# Get yours FREE at: https://aistudio.google.com/apikey
# This key is used for BOTH the LLM (text generation) and
# the embedding model (vector search).
GEMINI_API_KEY=your_gemini_api_key_here
